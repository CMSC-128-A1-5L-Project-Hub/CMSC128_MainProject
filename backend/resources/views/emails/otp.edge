<!DOCTYPE html>
<html>
<head>
  <style>
    .card { font-family: sans-serif; border: 1px solid #e2e8f0; padding: 2rem; border-radius: 8px; max-width: 400px; }
    .otp { font-size: 32px; font-weight: bold; color: #1e40af; letter-spacing: 5px; text-align: center; margin: 1rem 0; }
    .footer { font-size: 12px; color: #64748b; margin-top: 2rem; }
  </style>
</head>
<body>
  <div class="card">
    <h2>Verify your identity</h2>
    <p>Hi {{ firstName }},</p>
    <p>Use the code below to complete your registration for the <strong>UPLB Housing System</strong>.</p>
    
    <div class="otp">{{ otp }}</div>
    
    <p>This code will expire in <strong>{{ expiry }}</strong>.</p>
    
    <div class="footer">
      If you did not request this, please ignore this email.
    </div>
  </div>
</body>
</html>